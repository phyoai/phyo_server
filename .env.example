# Server Configuration
PORT=4000
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=512

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/phyo?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_jwt_secret_key_here

# API Keys
OPENAI_API_KEY=sk-proj-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
PERPLEXITY_API_KEY=pplx-xxxxx
RAPID_API_KEY=your_rapid_api_key
RAPID_API_HOST=instagram-statistics-api.p.rapidapi.com

# Data Scraping
BRIGHT_DATA_API_TOKEN=your_bright_data_token
BRIGHTSCRAPER_URL=http://127.0.0.1:5000

# AWS S3
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET_NAME=phyo-buck
AWS_S3_BUCKET=phyo-brand-asset

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx
RAZORPAY_WEBHOOK_SECRET=phyo_webhook_secret_2024

# Google OAuth
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# Admin Credentials
SUPER_ADMIN_EMAIL=superadmin@phyo.ai
SUPER_ADMIN_PASSWORD=SuperAdmin@123
