# BrightData API Configuration (Profile + Posts)
BRIGHTDATA_API_KEY=your_brightdata_key_here
BRIGHTDATA_DATASET_ID=your_profile_dataset_id
BRIGHTDATA_COMMENTS_DATASET_ID=your_comments_dataset_id  # Optional: Not used for scraping anymore

# RapidAPI Configuration (Comments - NEW!)
# Get your key from: https://rapidapi.com/social-api1-instagram/api/instagram-social-api
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI Configuration (Optional - for AI predictions)
OPENAI_API_KEY=your_openai_key_here

# Feature Toggles
USE_CACHE=True
USE_AI_PREDICTIONS=False  # Set to True to use GPT-3.5 instead of ML

# Flask Configuration
FLASK_DEBUG=True
PORT=5000
