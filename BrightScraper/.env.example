# BrightData API Configuration (Profile + Posts)
BRIGHTDATA_API_KEY=your_brightdata_key_here
BRIGHTDATA_DATASET_ID=your_profile_dataset_id
BRIGHTDATA_COMMENTS_DATASET_ID=your_comments_dataset_id  # Optional: Not used for scraping anymore

# RapidAPI Configuration (Comment Scraping - ACTIVE)
# Get your key from: https://rapidapi.com/social-api1-instagram/api/instagram-social-api
RAPIDAPI_KEY=your_rapidapi_key_here
MAX_COMMENTS_PER_POST=50  # How many comments to scrape per post (default: 50)

# Apify Configuration (DEPRECATED - Switched back to RapidAPI)
# APIFY_TOKEN=your_apify_token_here  # No longer used
# APIFY_ACTOR_ID=your_actor_id_here  # No longer used

# OpenAI Configuration (Optional - for AI predictions)
OPENAI_API_KEY=your_openai_key_here

# Feature Toggles
USE_CACHE=True
USE_AI_PREDICTIONS=False  # Set to True to use GPT-3.5 instead of ML

# Storage Configuration (NEW - to save disk space)
ENABLE_FILE_STORAGE=false  # Set to 'true' to save analysis results to scraped_data/
ENABLE_API_CACHING=false   # Set to 'true' to cache API responses in api_cache/

# Flask Configuration
FLASK_DEBUG=True
PORT=5000
